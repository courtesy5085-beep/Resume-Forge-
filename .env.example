# Database
DATABASE_URL="postgresql://resumeforge:resumeforge123@localhost:5432/resumeforge"
DATABASE_URL_SHADOW="postgresql://resumeforge:resumeforge123@localhost:5432/resumeforge_shadow"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production-key-12345"
NEXTAUTH_DEBUG=false

# API
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_SECRET_KEY="your-api-secret-key"
API_PORT=3001

# OpenAI
OPENAI_API_KEY="sk-proj-your-key-here"
OPENAI_MODEL="gpt-4-turbo-preview"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-key-here"
STRIPE_SECRET_KEY="sk_test_your-key-here"
STRIPE_WEBHOOK_SECRET="whsec_your-key-here"

# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="resumeforge-storage"

# SendGrid/Email
SENDGRID_API_KEY="SG.your-key-here"
EMAIL_FROM="noreply@resumeforge.ai"
EMAIL_VERIFICATION_TOKEN_SECRET="email-verification-secret"

# Redis
REDIS_URL="redis://localhost:6379"

# Environment
NODE_ENV="development"
NEXT_PUBLIC_ENV="development"

# Feature Flags
FEATURE_INTERVIEW_PREP=true
FEATURE_LINKEDIN_OPTIMIZER=true
FEATURE_JOB_MATCHER=true
FEATURE_TEAM_COLLABORATION=false

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=""
NEXT_PUBLIC_SENTRY_DSN=""

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Credits
FREE_PLAN_MONTHLY_CREDITS=5
PRO_PLAN_MONTHLY_CREDITS=1000
